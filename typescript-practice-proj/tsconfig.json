{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./out",
    "sourceMap": true,
    "paths": {
      "@utils/*": ["./src/utils/*"],
      "@typings/*": ["./src/typings/*"],
      "@models/*": ["./src/models/*"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "out"]
}
